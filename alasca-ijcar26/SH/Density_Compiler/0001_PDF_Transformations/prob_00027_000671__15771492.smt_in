(assert (! (forall ((?v0 Nat$) (?v1 Nat$)) (=> (and (fun_app$a (fun_app$b less_eq$ ?v0) (fun_app$g suc$ ?v1)) (and (=> (fun_app$a (fun_app$b less_eq$ ?v0) ?v1) false) (=> (= ?v0 (fun_app$g suc$ ?v1)) false))) false)) :named a604))
(assert (! (forall ((?v0 Nat$) (?v1 Nat$)) (=> (fun_app$a (fun_app$b less_eq$ (fun_app$g suc$ ?v0)) ?v1) (fun_app$a (fun_app$b less_eq$ ?v0) ?v1))) :named a605))
(check-sat)
;- (get-unsat-core)
