(assert (! (forall ((?v0 Nat$) (?v1 Nat$)) (= (not (fun_app$e (fun_app$f less$ ?v0) ?v1)) (fun_app$e (fun_app$f less$ ?v1) (fun_app$i suc$ ?v0)))) :named a602))
(assert (! (forall ((?v0 Nat$) (?v1 Nat$)) (= (fun_app$e (fun_app$f less$ ?v0) (fun_app$i suc$ ?v1)) (or (fun_app$e (fun_app$f less$ ?v0) ?v1) (= ?v0 ?v1)))) :named a603))
(check-sat)
;- (get-unsat-core)
