(set-info :smt-lib-version 2.6)
(set-logic UFLRA)
(set-info :source | Buggy list theorem |)
(set-info :category "crafted")
(set-info :status sat)
(set-info :difficulty | 5 |)
(declare-sort List 0)
(declare-fun cons (Real List) List)
(declare-fun nil () List)
(declare-fun car (List) Real)
(declare-fun cdr (List) List)
(assert (forall ((?x Real) (?y List)) (= (car (cons ?x ?y)) ?x)))
(assert (not (forall ((?x1 Real) (?y1 List) (?x2 Real) (?y2 List)) (=> (= (cons ?x1 ?y1) (cons ?x2 ?y2)) (and (= ?x1 ?x2) (= ?y1 ?y2))))))
(check-sat)
(exit)
