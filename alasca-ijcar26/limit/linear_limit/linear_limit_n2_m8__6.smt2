; Problem:
; 
;     lim(f_1 x) = l_1
;     ...
;     lim(f_n x) = l_n
;     =================
;     lim(k_1 f_{i_1}(x) + ... + k_m f_{i_m}(x)) = k1 l_{i_1} ... k_m  l_{i_m}
; 
; with n = 2
;      m = 8
;      k_i in Q
;      i_j in {1..n}

(declare-fun f0 (Real) Real)
(declare-fun f1 (Real) Real)
(declare-const l0 Real)
(declare-const l1 Real)
(declare-const a Real)
; Axiom 0
(assert ; lim[x -> a](f0 x) = l0
        ;
        ; forall epsilon > 0
        (forall ((epsilon Real)) (=> (< 0.0 epsilon)
          ;
          ; exists delta > 0
          (exists ( (delta Real) ) (and (< 0.0 delta)
            (forall ((x Real)) (=> ;
                                          ; a != x
                                     (and (not (= x a))
                                          ; | x - a | < delta
                                          (< (ite (>= (- x a) 0.0) (- x a) (- (- x a))) delta))
                                     ;
                                     ; | (f0 x) - l0 | < epsilon
                                     (< (ite (>= (- (f0 x) l0) 0.0) (- (f0 x) l0) (- (- (f0 x) l0))) epsilon)
            ))
          ))
        )))

; Axiom 1
(assert ; lim[x -> a](f1 x) = l1
        ;
        ; forall epsilon > 0
        (forall ((epsilon Real)) (=> (< 0.0 epsilon)
          ;
          ; exists delta > 0
          (exists ( (delta Real) ) (and (< 0.0 delta)
            (forall ((x Real)) (=> ;
                                          ; a != x
                                     (and (not (= x a))
                                          ; | x - a | < delta
                                          (< (ite (>= (- x a) 0.0) (- x a) (- (- x a))) delta))
                                     ;
                                     ; | (f1 x) - l1 | < epsilon
                                     (< (ite (>= (- (f1 x) l1) 0.0) (- (f1 x) l1) (- (- (f1 x) l1))) epsilon)
            ))
          ))
        )))


