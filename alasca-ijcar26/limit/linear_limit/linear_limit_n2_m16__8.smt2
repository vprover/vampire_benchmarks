; Axiom 0
(assert ; lim[x -> a](f0 x) = l0
        ;
        ; forall epsilon > 0
        (forall ((epsilon Real)) (=> (< 0.0 epsilon)
          ;
          ; exists delta > 0
          (exists ( (delta Real) ) (and (< 0.0 delta)
            (forall ((x Real)) (=> ;
                                          ; a != x
                                     (and (not (= x a))
                                          ; | x - a | < delta
                                          (< (ite (>= (- x a) 0.0) (- x a) (- (- x a))) delta))
                                     ;
                                     ; | (f0 x) - l0 | < epsilon
                                     (< (ite (>= (- (f0 x) l0) 0.0) (- (f0 x) l0) (- (- (f0 x) l0))) epsilon)
            ))
          ))
        )))

; Axiom 1
(assert ; lim[x -> a](f1 x) = l1
